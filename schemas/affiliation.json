{
	"title": "Affiliation",
	"description": "Affiliation is an institution with which an author is associated.",
	"required": [
		"authorId"
	],
	"properties": {
		"id": {
			"type": "integer",
			"description": "The unique ID of an affiliation in the database.",
			"readOnly": true,
			"apiSummary": true
		},
		"authorId": {
			"type": "integer",
			"description": "The author with which this affiliation is associated.",
			"writeDisabledInApi": true,
			"apiSummary": true
		},
		"ror": {
			"type": "string",
			"description": "The [ROR](https://ror.org/) ID of this institution.",
			"apiSummary": true,
			"validation": [
				"nullable",
				"regex:#https://ror.org/0[^ILOU]{6}\\d{2}#"
			]
		},
		"rorObject": {
			"type": "object",
			"description": "An object representing the ROR for this affiliation.",
			"apiSummary": true,
			"readOnly": true,
			"$ref": "#/definitions/Ror"
		},
		"name": {
			"type": "string",
			"description": "The name of this institution.",
			"multilingual": true,
			"apiSummary": true,
			"validation": [
				"nullable"
			]
		}
	}
}
