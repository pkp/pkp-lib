msgstr "Oświadczenie o ochronie prywatności"

msgid "acceptInvitation.userDetailsForm.givenName.description"
msgstr ""
"Nazywane również imieniem lub imieniem własnym, jest to ta część imienia i "
"nazwiska, która pozwala zidentyfikować daną osobę."

msgid "acceptInvitation.userDetailsForm.familyName.description"
msgstr ""
"Nazwisko to ta część imienia i nazwiska, która jest zazwyczaj dziedziczna i "
"wskazuje na przynależność do danej rodziny."

msgid "acceptInvitation.userDetailsForm.affiliation.description"
msgstr "To jest instytucja, z którą jesteś powiązany"

msgid "acceptInvitation.userDetailsForm.countryOfAffiliation.description"
msgstr ""
"Jest to kraj, w którym znajduje się instytucja, z którą jesteś powiązany"

msgid "acceptInvitation.userDetailsForm.countryOfAffiliation.label"
msgstr "Kraj afiliacji"

