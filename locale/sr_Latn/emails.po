msgstr "Zahtev za ažuriranje ORCID dozvola"

msgid "emails.userRoleAssignmentInvitationNotify.userGroupSection"
msgstr ""
"<div class='section'>         <div class='section-number'>{$sectionNumber}.</"
"div>    <div class='section-content'>       <h2>\n"
"{$sectionName}</h2>        <p>Početak od {$dateStart}</p>        "
"<p>{$sectionEndingDate}</p>        <p>{$sectionMastheadAppear}\n"
"</p>    </div></div>"

msgid "mailable.userRoleEndNotify.name"
msgstr "Obaveštenje o isteku korisničke uloge"

msgid "mailable.userRoleEndNotify.description"
msgstr "Imejl obaveštenje koje se šalje korisniku kada mu je uklonjena uloga."

msgid "emails.userRoleEndNotify.subject"
msgstr "Uklonjeni ste iz uloge"

msgid "mailable.userRoleAssignmentInvitationNotify.name"
msgstr "Korisnik je pozvan na ulogu"

msgid "emails.userRoleAssignmentInvitationNotify.subject"
msgstr "Pozvani ste na nove uloge"

msgid "mailable.userRoleAssignmentInvitationNotify.description"
msgstr ""
"Ovaj imejl se šalje korisnicima koji su pozvani da dobiju određene uloge"

msgid "emails.userRoleAssignmentInvitationNotify.body"
msgstr ""
"<div class='email-container'>   <div class='email-"
"header'>                       <h2>Poziv na novu ulogu</h2>    </div>   \n"
"<div class='email-content'>        <p>Poštovani/a {$recipientName},</"
"p>        <p>U skladu sa vašom stručnošću, {$inviterName} vas je pozvao/la "
"da preuzmete nove uloge u okviru {$contextName}.</p>        <p>U "
"{$contextName} cenimo vašu privatnost. Zbog toga smo preduzeli korake kako "
"bismo bili u potpunosti usklađeni sa GDPR-om. Ovi koraci uključuju to da "
"sami unosite svoje podatke i birate ko može da vidi koje informacije. Za "
"dodatne informacije o tome kako rukujemo vašim podacima, pogledajte našu "
"Politiku privatnosti.</p>        <div>{$existingRoles}</div>\n"
"        <div>{$rolesAdded}</div>        <p>Nakon prihvatanja poziva, bićete "
"preusmereni na {$contextName}.</p>        <p>Slobodno me kontaktirajte ako "
"imate bilo kakvih pitanja u vezi sa procesom.</p>        "
"<table class='btn-wrap' role='presentation' border='0' cellpadding='0' cellspacing='10'>"
"            <tr><td class='btn-cell btn-accept'  bgcolor='#28a745'><a class='btn' href='{$acceptUrl}'>Prihvati poziv</a></td></tr>"
"            <tr><td class='btn-cell btn-decline' bgcolor='#dc3545'><a class='btn' href='{$declineUrl}'>Odbij poziv</a></td></tr>"
"        </table>"
"        <p>Srdačan pozdrav,</p>        <p>{$contextName}</p>\n"
"    </div></div>"

msgid "orcid.orcidCollectAuthorId.name"
msgstr "orcidCollectAuthorId"

msgid "emails.userRoleAssignmentInvitationNotify.userGroupSectionEndingDate"
msgstr "Završava se {$dateEnd}"

msgid "emails.userRoleAssignmentInvitationNotify.userGroupSectionWillNotAppear"
msgstr ""
"Vaše ime neće biti prikazano u impresumu časopisa {$contextName} kao "
"{$sectionName}."

msgid "emailTemplate.variable.userRoleEnd.roleRemoved"
msgstr "Ovo je naziv korisničke uloge koja je uklonjena"

msgid "emails.userRoleEndNotify.body"
msgstr ""
"<div class='email-container'>   <div class='email-header'>        "
"<h2>Uklonjeni ste iz uloge</h2>    </div>   \n"
"<div class='email-content'>       <p>Poštovani/a {$recipientName},</"
"p>        <p>Hvala vam na učešću u ulozi {$roleRemoved} u okviru \n"
"{$contextName}.</p>        <p>Ovim putem vas obaveštavamo da ste uklonjeni "
"iz sledeće uloge u okviru\n"
" {$contextName}: <b>{$roleRemoved}</b>.</p>        <p>Vaš nalog na "
"{$contextName} je i dalje aktivan, kao i sve druge uloge koje ste prethodno "
"\n"
"imali.</p>        <p>Slobodno me kontaktirajte ukoliko imate bilo kakva "
"pitanja u vezi sa ovim postupkom.</p>        <p>Srdačan pozdrav,</p>       "
"<p>{$contextName}</p>   </div></div>"

msgid "emails.userRoleMastheadUpdateNotify.subject"
msgstr "Vidljivost vašeg imena u impresumu časopisa je ažurirana"

msgid "mailable.userRoleMastheadUpdateNotify.description"
msgstr ""
"Imejl obaveštenje koje se šalje korisniku kada se ažurira vidljivost "
"njegovog/njenog impresuma za određenu ulogu."

msgid "mailable.userRoleMastheadUpdateNotify.name"
msgstr ""
"Obaveštenje o ažuriranju vidljivosti u impresumu (spisku uredništva) za "
"korisničku ulogu"

msgid "emailTemplate.variable.userRoleMastheadUpdateNotify.roleNameAndDates"
msgstr ""
"Ovo je naziv, datum početka i datum završetka korisničke uloge za koju je "
"ažurirana vidljivost u impresumu"

msgid "emailTemplate.variable.userRoleMastheadUpdateNotify.roleNameAndDates.value"
msgstr "{$roleName} ({$startDate} &ndash; {$endDate})"

msgid "emailTemplate.variable.userRoleMastheadUpdateNotify.roleNameAndDates.startDate"
msgstr "{$roleName} (since {$startDate})"

msgid "emailTemplate.variable.userRoleMastheadUpdateNotify.roleNameAndDates.endDate"
msgstr "{$roleName} (until {$endDate})"

msgid "emailTemplate.variable.userRoleMastheadUpdateNotify.appearOnMasthead"
msgstr "Poruka ako se korisnik prikazuje u impresumu za tu ulogu."

msgid "emails.userRoleMastheadUpdateNotify.body"
msgstr ""
"<div class='email-container'>    <div class='email-header'>       "
"<h2>Ažurirana vidljivost u impresumu za ulogu</h2>    </div>    \n"
"<div class='email-content'>        <p>Poštovani/a {$recipientName},</"
"p>        <p>Vidljivost vašeg prikaza u impresumu časopisa za ulogu "
"{$roleNameAndDates} u okviru {$contextName} je ažurirana.</p>        <p>Novo "
"podešavanje: {$appearOnMasthead}</p>        <p>Ukoliko imate \n"
"pitanja u vezi sa ovom promenom, molimo vas da kontaktirate urednika "
"časopisa.</p>        <p>Srdačan pozdrav,</p>        <p>{$contextName}</"
"p>       </div>\n"
"</div>"

msgid "emails.userRoleAssignmentInvitationNotify.userGroupSectionWillAppear"
msgstr ""
"Vaše ime će biti prikazano u impresumu časopisa {$contextName} kao "
"{$sectionName}."

msgid "emails.userRoleAssignmentInvitationNotify.alreadyAssignedRoles"
msgstr "<p><h2>Već dodeljene uloge</h2></p>"

msgid "emailTemplate.variable.invitation.recipientName"
msgstr "Ovo je ime primaoca poziva"

msgid "emailTemplate.variable.invitation.inviterName"
msgstr "Ovo je ime pošiljaoca poziva"

msgid "emailTemplate.variable.invitation.inviterRole"
msgstr "Ovo je uloga pošiljaoca poziva"

msgid "emailTemplate.variable.invitation.existingRoles"
msgstr "Ovaj deo opisuje uloge koje korisnik već ima."

msgid "emailTemplate.variable.invitation.acceptUrl"
msgstr "Ovo je URL za prihvatanje poziva"

msgid "emails.userRoleAssignmentInvitationNotify.newlyAssignedRoles"
msgstr "<p><h2>Nove dodeljene uloge</h2><p>"

msgid "emailTemplate.variable.invitation.rolesAdded"
msgstr ""
"Ovaj deo opisuje uloge koje će korisniku biti dodeljene nakon prihvatanja "
"poziva"

msgid "emailTemplate.variable.invitation.declineUrl"
msgstr "Ovo je URL za odbijanje poziva"
