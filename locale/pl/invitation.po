msgstr "Formularz danych użytkownika przyjmującego zaproszenie"

msgid "acceptInvitation.userDetails.form.description"
msgstr ""
"Prosimy o podanie poniższych danych, abyśmy mogli lepiej zarządzać Państwa "
"kontem"

msgid "acceptInvitation.detailsReview.stepName"
msgstr "Przejrzyj i załóż konto"

