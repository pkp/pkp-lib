msgid "invitation.familyName.description"
msgstr ""
"Če poznate priimek uporabnika, lahko vnesete te podatke. Vendar pa lahko "
"uporabnik te podatke spremeni."

msgid "acceptInvitation.userDetailsForm.givenName.description"
msgstr ""
