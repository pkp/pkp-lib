msgid "emails.submissionAck.subject"
msgstr "Hvala vam na dostavljenom radu u {$contextName}"

msgid "emails.submissionAck.body"
msgstr ""
"<p>Poštovani/Poštovana {$recipientName},</p><p>Hvala vam na slanju vašeg "
"rada u {$contextName}. Primili smo vaš rad „{$submissionTitle}“ i član našeg "
"uredničkog tima će ga uskoro pregledati. Bićete obavešteni putem imejla kada "
"bude doneta početna odluka, a možemo vas kontaktirati i ukoliko budu "
"potrebne dodatne informacije.</p><p>Vaš rad možete pregledati i pratiti "
"njegov napredak kroz urednički proces na sledećoj adresi:</p><p>URL rada: "
"{$authorSubmissionUrl}</p><p>Ako ste odjavljeni iz sistema, možete se ponovo "
"prijaviti koristeći korisničko ime {$recipientUsername}.</p><p>Ako imate "
"bilo kakvih pitanja, možete me kontaktirati putem svog <a href=\""
"{$authorSubmissionUrl}\">kontrolnog panela za prijave</a>.</p><p>Hvala vam "
"što ste izabrali {$contextName} kao mesto za objavljivanje vašeg "
"rada.</p>{$contextSignature}"

msgid "emails.submissionAck.description"
msgstr "Ova poruka e-pošte se automatski šalje autoru kada podnese svoj rad."

msgid "emails.reviewAck.subject"
msgstr "Hvala vam na recenziji"

msgid "emails.reviewAck.body"
msgstr ""
"<p>Poštovani/Poštovana {$recipientName},</p>\n"
"<p>Hvala vam što ste završili recenziju rada „{$submissionTitle}“ za "
"{$contextName}. Zahvaljujemo vam na vremenu i stručnosti koje ste uložili u "
"doprinos kvalitetu radova koje objavljujemo.</p>\n"
"<p>Bilo nam je zadovoljstvo sarađivati sa vama kao recenzentom za "
"{$contextName} i nadamo se da ćemo imati priliku da ponovo sarađujemo u "
"budućnosti.</p>\n"
"<p>Srdačan pozdrav,</p>\n"
"<p>{$signature}</p>"

msgid "emails.decision.notifyReviewers.subject"
msgstr "Hvala Vam na recenziji"

msgid "emails.decision.notifyReviewers.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p>\n"
"<p>Hvala vam što ste završili recenziju rada „{$submissionTitle}“ za "
"{$contextName}. Cenimo vaše vreme i stručnost koje doprinosite kvalitetu "
"radova koje objavljujemo. Vaše komentare smo prosledili autorima, zajedno sa "
"komentarima ostalih recenzenata i odlukom urednika.</p>\n"
"<p>Na osnovu dobijenih povratnih informacija, autore smo obavestili o "
"sledećem:</p>\n"
"<p>{$decisionDescription}</p>\n"
"<p>Vaša preporuka je razmotrena zajedno sa preporukama drugih recenzenata "
"pre donošenja konačne odluke. Povremeno se može desiti da se odluka urednika "
"razlikuje od preporuke jednog ili više recenzenata. Urednik uzima u obzir "
"više faktora i ove odluke se ne donose olako. Zahvalni smo našim "
"recenzentima na stručnosti i predlozima.</p>\n"
"<p>Bilo nam je zadovoljstvo sarađivati s vama kao recenzentom za "
"{$contextName} i nadamo se da ćemo imati priliku da ponovo sarađujemo u "
"budućnosti.</p>\n"
"<p>Srdačan pozdrav,</p>\n"
"<p>{$signature}</p>"

msgid "emails.decision.notifyOtherAuthors.subject"
msgstr "Novosti u vezi sa vašim radom"

msgid "emails.decision.notifyOtherAuthors.body"
msgstr ""
"<p>Sledeći imejl je poslat korisniku {$submittingAuthorName} od strane "
"{$contextName} u vezi sa „{$submissionTitle}“.</p>\n"
"<p>Ovu poruku dobijate kao kopiju jer ste navedeni kao autor rada. Sve "
"instrukcije u nastavku poruke namenjene su autoru koji je podneo rad, "
"{$submittingAuthorName}, i od vas se u ovom trenutku ne zahteva nikakva "
"akcija.</p>\n"
"\n"
"{$messageToSubmittingAuthor}"

msgid "emails.editorDecisionSendToExternal.subject"
msgstr "Vaš rad je poslat na recenziju"

msgid "emails.editorDecisionSendToExternal.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Drago mi je da vas obavestim da je "
"urednik pregledao vaš rad „{$submissionTitle}“ i odlučio da ga pošalje na "
"recenziju. Urednik će odabrati kvalifikovane recenzente koji će dati "
"povratne informacije o vašem radu.</p><p>{$reviewTypeDescription} Od nas "
"ćete dobiti povratne informacije od recenzenata i informacije o narednim "
"koracima.</p><p>Napominjemo da slanje rada na recenziju ne garantuje njegovo "
"objavljivanje. Pre nego što donesemo odluku o prihvatanju rada za "
"objavljivanje, razmotrićemo preporuke recenzenata. Može se desiti da od vas "
"bude zatraženo da izvršite izmene i odgovorite na komentare recenzenata pre "
"nego što se donese konačna odluka.</p><p>Ukoliko imate pitanja, "
"kontaktirajte me putem vašeg kontrolnog panela za "
"prijave.</p><p>{$signature}</p>"

msgid "emails.editorDecisionSendToProduction.subject"
msgstr "Sledeći koraci za objavljivanje vašeg rada"

msgid "emails.editorDecisionSendToProduction.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Javljam vam se u ime {$contextName} "
"da vas obavestim da je uređivanje vašeg predatog rada „{$submissionTitle}“ "
"završeno. Vaš rad će sada preći u fazu produkcije, gde će konačni prelomi "
"biti pripremljeni za objavljivanje. Kontaktiraćemo vas ukoliko bude potrebna "
"dodatna saradnja.</p><p>Ako imate bilo kakvih pitanja, kontaktirajte me "
"putem vaše <a href=\"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</"
"p><p>Srdačan pozdrav,</p>{$signature}"

msgid "emails.editorDecisionRevisions.subject"
msgstr "Vaš rad je recenziran i podstičemo vas da dostavite izmene"

msgid "emails.editorDecisionRevisions.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Vaš rad „{$submissionTitle}“ je "
"recenziran i želeli bismo da vas podstaknemo da dostavite izmene koje "
"odgovaraju na komentare recenzenata. Urednik će pregledati ove izmene i, "
"ukoliko na odgovarajući način adresiraju primedbe, vaš rad može biti "
"prihvaćen za objavljivanje.</p><p>Komentari recenzenata nalaze se na kraju "
"ovog imejla. Molimo vas da odgovorite na svaku tačku iz komentara "
"recenzenata i navedete koje ste izmene napravili. Ukoliko smatrate da su "
"neki komentari recenzenata neosnovani ili neprimereni, molimo vas da "
"obrazložite svoj stav.</p><p>Kada završite izmene, možete otpremiti "
"revidirane dokumente zajedno sa vašim odgovorima na komentare recenzenata "
"putem vaše <a href=\"{$authorSubmissionUrl}\">kontrolne table prijave</a>. "
"Ako ste odjavljeni, možete se ponovo prijaviti koristeći korisničko ime "
"{$recipientUsername}.</p><p>Ako imate bilo kakvih pitanja, kontaktirajte me "
"putem vaše <a href=\"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</"
"p><p>Radujemo se prijemu vašeg revidiranog rada.</p><p>Srdačan "
"pozdrav,</p>{$signature}<hr><p>Sledeći komentari su primljeni od "
"recenzenata.</p>{$allReviewerComments}"

msgid "emails.editorDecisionResubmit.subject"
msgstr "Vaš rad je recenziran — molimo vas da ga izmenite i ponovo pošaljete"

msgid "emails.editorDecisionResubmit.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Nakon razmatranja vašeg rada "
"„{$submissionTitle}“, recenzenti su preporučili da se u trenutnom obliku ne "
"može prihvatiti za objavljivanje. Međutim, podstičemo vas da dostavite "
"revidiranu verziju koja odgovara na komentare recenzenata. Vaše izmene će "
"biti pregledane od strane urednika i mogu biti upućene u još jedan krug "
"stručne recenzije.</p><p>Napominjemo da ponovno podnošenje vašeg rada ne "
"garantuje njegovo prihvatanje.</p><p>Komentari recenzenata nalaze se na "
"kraju ovog imejla. Molimo vas da odgovorite na svaku tačku i navedete koje "
"ste izmene izvršili. Ako smatrate da su neki komentari recenzenata "
"neprimereni, molimo vas da obrazložite svoj stav. Ukoliko imate pitanja u "
"vezi sa preporukama iz recenzije, uključite ih u vaš odgovor.</p><p>Kada "
"završite izmene, možete otpremiti revidirane dokumente zajedno sa vašim "
"odgovorima na komentare recenzenata <a href=\"{$authorSubmissionUrl}\">putem "
"vaše kontrolne table prijave</a>. Ako ste odjavljeni, možete se ponovo "
"prijaviti koristeći korisničko ime {$recipientUsername}.</p><p>Ako imate "
"bilo kakvih pitanja, kontaktirajte me putem vaše <a href=\""
"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</p><p>Radujemo se "
"prijemu vašeg revidiranog rada.</p><p>Srdačan pozdrav,</p>{$signature}"
"<hr><p>Sledeći komentari su primljeni od "
"recenzenata.</p>{$allReviewerComments}"

msgid "emails.editorDecisionDecline.subject"
msgstr "Vaša rad je odbijen"

msgid "emails.editorDecisionDecline.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Iako cenimo rad koji se podneli, na "
"osnovu komentara recenzenata nismo u mogućnosti da prihvatimo "
"„{$submissionTitle}“ za objavljivanje.</p><p>Komentari recenzenata nalaze se "
"na kraju ovog imejla.</p><p>Hvala vam što ste podneli rad u {$contextName}. "
"Iako je odbijanje rada razočaravajuće, nadamo se da će vam komentari "
"recenzenata biti konstruktivni i korisni.</p><p>Sada ste slobodni da ovaj "
"rad pošaljete drugom časopisu ako to želite.</p><p>Srdačan "
"pozdrav,</p>{$signature}<hr><p>Sledeći komentari su primljeni od "
"recenzenata.</p>{$allReviewerComments}"

msgid "emails.editorRecommendation.subject"
msgstr "Preporuka urednika"

msgid "emails.editorRecommendation.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Nakon razmatranja komentara "
"recenzenata, želeo/la bih da dam sledeću preporuku u vezi sa radom "
"„{$submissionTitle}“.</p><p>Moja preporuka je: {$recommendation}.</"
"p><p>Molimo vas da posetite <a href=\"{$submissionUrl}\">urednički radni "
"tok</a> prijave kako biste postupili po ovoj preporuci.</p><p>Slobodno me "
"kontaktirajte ako imate bilo kakvih pitanja.</p><p>Srdačan "
"pozdrav,</p><p>{$senderName}</p>"

msgid "emails.copyeditRequest.subject"
msgstr "Rad {$submissionId} je spreman za lekturu za {$contextAcronym}"

msgid "emails.copyeditRequest.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Novi rad je spreman za lekturu:</"
"p><p><a href=\"{$submissionUrl}\">{$submissionId} — „{$submissionTitle}“</"
"a><br />{$contextName}</p><p>Molimo vas da sledite sledeće korake kako biste "
"završili ovaj zadatak:</p><ol><li>Kliknite na URL rada u nastavku.</"
"li><li>Otvorite sve fajlove dostupne u sekciji Nacrt fajlova i uredite ih. "
"Koristite odeljak za lektorske diskusije ako je potrebno da kontaktirate "
"urednike ili autore.</li><li>Sačuvajte lektorisane fajlove i otpremite ih u "
"sekciju Lektorisanih fajlova.</li><li>Koristite lektorske diskusije da "
"obavestite urednike da su svi fajlovi pripremljeni i da produkcija može da "
"počne.</li></ol><p>Ako trenutno niste u mogućnosti da preuzmete ovaj zadatak "
"ili imate pitanja, molimo vas da me kontaktirate. Hvala vam na doprinosu za "
"{$contextName}.</p><p>Srdačan pozdrav,</p>{$signature}"

msgid "emails.editorDecisionNewReviewRound.subject"
msgstr "Vaš rad je poslat na još jedan krug recenzije"

msgid "emails.editorDecisionNewReviewRound.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p>\n"
" <p>Vaša revidirani rad „{$submissionTitle}“ poslat je na novi krug stručne "
"recenzije. Kontaktiraćemo vas sa povratnim informacijama od recenzenata i "
"informacijama o narednim koracima.</p>\n"
" <p>Ako imate bilo kakvih pitanja, kontaktirajte me putem vaše <a href=\""
"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</p>\n"
" <p>Srdačan pozdrav,</p> \n"
"<p>{$signature}</p>\n"

msgid "emails.editorDecisionRevertDecline.subject"
msgstr "Povukli smo odluku o odbijanju vašeg rada"

msgid "emails.editorDecisionRevertDecline.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p> \n"
"<p>Odluka o odbijanju vašeg rada „{$submissionTitle}“ je povučena. \n"
"Urednik će završiti krug recenzije i bićete obavešteni kada\n"
" odluka bude doneta.</p>\n"
" <p>Povremeno se dešava da se odluka o odbijanju rada slučajno evidentira u\n"
" sistemu i mora biti poništena. Izvinjavamo se zbog eventualne zabune koju "
"je ovo moglo izazvati.</p>\n"
" <p>Kontaktiraćemo vas ukoliko bude potrebna dodatna pomoć.</p> \n"
"<p>Ako imate bilo kakvih pitanja, kontaktirajte me putem vaše <a href=\""
"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</p>\n"
" <p>Srdačan pozdrav,</p>\n"
" <p>{$signature}</p>\n"

msgid "emails.editorDecisionRevertInitialDecline.subject"
msgstr "Povukli smo odluku o odbijanju vašeg rada"

msgid "emails.editorDecisionRevertInitialDecline.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p>\n"
"<p>Odluka o odbijanju vašeg rada „{$submissionTitle}“ je povučena. \n"
"Urednik će dodatno razmotriti vaš rad pre nego što donese odluku da li će "
"rad biti odbijen \n"
"ili poslat na recenziju.</p>\n"
"<p>Povremeno se dešava da se odluka o odbijanju rada slučajno evidentira u\n"
" našem sistemu i mora biti poništena. Izvinjavamo se zbog eventualne zabune "
"koju je ovo moglo izazvati.</p>\n"
"<p>Kontaktiraćemo vas ukoliko bude potrebna dodatna pomoć.</p>\n"
"<p>Ako imate bilo kakvih pitanja, kontaktirajte me putem vaše <a href=\""
"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</p>\n"
"<p>Srdačan pozdrav,</p>\n"
"<p>{$signature}</p>\n"

msgid "emails.editorDecisionInitialDecline.subject"
msgstr "Vaš rad je odbijen"

msgid "emails.editorDecisionInitialDecline.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Žao mi je što vas obaveštavam da, "
"nakon razmatranja vašeg rada „{$submissionTitle}“, urednik smatra da on ne "
"ispunjava naše uslove za objavljivanje u časopisu {$contextName}.</"
"p><p>Želim vam uspeh ukoliko odlučite da svoj rad pošaljete drugde.</"
"p><p>Srdačan pozdrav,</p>{$signature}"

msgid "emails.editorialReminder.subject"
msgstr "Nezavršeni urednički zadaci za {$contextName}"

msgid "emails.editorialReminder.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Trenutno ste dodeljeni za "
"{$numberOfSubmissions} radova u okviru <a href=\"{$contextUrl}\""
">{$contextName}</a>. Sledeći prijavljeni radovi <b>čekaju vaš "
"odgovor</b>.</p>{$outstandingTasks}<p>Sve svoje zadatke možete pregledati na "
"<a href=\"{$submissionsUrl}\">kontrolnoj tabli prijava</a>.</p><p>Ako imate "
"bilo kakvih pitanja u vezi sa svojim zadacima, kontaktirajte {$contactName} "
"na {$contactEmail}.</p>"

msgid "discussion.notification.description"
msgstr ""
"Ovaj imejl se šalje kada korisnik kreira novu diskusiju ili odgovori na "
"postojeću diskusiju"

msgid "emails.editorDecisionBackFromProduction.subject"
msgstr "Vaš rad je vraćen na lekturu"

msgid "emails.editorDecisionBackFromProduction.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Vaš rad „{$submissionTitle}“ je "
"vraćen u fazu lekture, gde će proći dodatnu lekturu i formatiranje radi "
"pripreme za objavljivanje.</p><p>Povremeno se dešava da rad bude poslat u "
"fazu produkcije pre nego što je u potpunosti spreman za finalnu pripremu "
"preloma za objavljivanje. Vaš rad je i dalje u procesu. Izvinjavamo se zbog "
"eventualne zabune.</p><p>Ako imate bilo kakvih pitanja, kontaktirajte me "
"putem vaše <a href=\"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</"
"p><p>Kontaktiraćemo vas ukoliko bude potrebna dodatna pomoć.</p><p>Srdačan "
"pozdrav,</p><p>{$signature}</p>"

msgid "emails.editorDecisionBackFromCopyediting.subject"
msgstr "Vaš rad je vraćen na recenziju"

msgid "emails.editorDecisionBackFromCopyediting.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Vaš rad „{$submissionTitle}“ je "
"vraćen u fazu recenzije. Biće podvrgnut dodatnoj recenziji pre nego što može "
"biti prihvaćen za objavljivanje.</p><p>Povremeno se dešava da se odluka o "
"prihvatanju rada slučajno evidentira u našem sistemu, te je potrebno vratiti "
"ga u fazu recenzije. Izvinjavamo se zbog eventualne zabune. Nastojimo da "
"dodatnu recenziju završimo što je pre moguće kako biste dobili konačnu "
"odluku u najkraćem roku.</p><p>Kontaktiraćemo vas ukoliko bude potrebna "
"dodatna pomoć.</p><p>Ako imate bilo kakvih pitanja, kontaktirajte me putem "
"vaše <a href=\"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</"
"p><p>Srdačan pozdrav,</p><p>{$signature}</p>"

msgid "emails.editorDecisionCancelReviewRound.subject"
msgstr "Krug recenzije za vaš rad je otkazan"

msgid "emails.editorDecisionCancelReviewRound.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Nedavno smo otvorili novi krug "
"recenzije za vaš rad „{$submissionTitle}“. Ovim putem zatvaramo taj krug "
"recenzije.</p><p>Povremeno se dešava da se odluka o otvaranju kruga "
"recenzije slučajno evidentira u našem sistemu, te je potrebno da se taj krug "
"otkaže. Izvinjavamo se zbog eventualne zabune koju je ovo moglo izazvati.</"
"p><p>Kontaktiraćemo vas ukoliko bude potrebna dodatna pomoć.</p><p>Ako imate "
"bilo kakvih pitanja, kontaktirajte me putem vaše <a href=\""
"{$authorSubmissionUrl}\">kontrolne table prijave</a>.</p><p>Srdačan "
"pozdrav,</p><p>{$signature}</p>"

msgid "emails.reviewResendRequest.subject"
msgstr "Ponovni zahtev za vašu recenziju za {$contextName}"

msgid "emails.reviewResendRequest.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Nedavno ste odbili naš zahtev za "
"recenziju rada „{$submissionTitle}“ za {$contextName}. Pišem vam da proverim "
"da li ste ipak u mogućnosti da izvršite ovu recenziju.</p><p>Bilo bi nam "
"veoma značajno ukoliko možete da prihvatite ovaj zadatak, ali razumemo ako "
"to trenutno nije moguće. U svakom slučaju, molimo vas da <a href=\""
"{$reviewAssignmentUrl}\">prihvatite ili odbijete zahtev</a> do "
"{$responseDueDate}, kako bismo mogli da pronađemo alternativnog recenzenta.</"
"p><p>Ako imate bilo kakvih pitanja, kontaktirajte me.</p><p>Srdačan "
"pozdrav,</p>{$signature}"

msgid "emails.footer.unsubscribe"
msgstr ""
"<br><br>—<br><a href=\"{$unsubscribeUrl}\">Odjavite se</a> sa primanja "
"imejlova iz <a href=\"{$contextUrl}\">{$contextName}</a>."

msgid "emails.footer.unsubscribe.discussion"
msgstr ""
"<br><br>—<br>Odgovorite na ovaj komentar na <a href=\"{$submissionUrl}\""
">#{$submissionId} {$authorsShort}</a> ili se <a href=\"{$unsubscribeUrl}\""
">odjavite</a> sa primanja imejlova iz <a href=\"{$contextUrl}\""
">{$contextName}</a>."

msgid "emails.footer.unsubscribe.automated"
msgstr ""
"<br><br>—<br>Ovo je automatska poruka iz <a href=\"{$contextUrl}\""
">{$contextName}</a>. Možete se <a href=\"{$unsubscribeUrl}\">odjaviti</a> sa "
"primanja ovih imejlova u bilo kom trenutku."

msgid "emailTemplate.variable.unsubscribe"
msgstr "Link za odjavu sa ovog imejla."

msgid "emails.discussion.subject"
msgstr "Poruka u vezi sa {$contextName}"

msgid "emails.discussion.body"
msgstr "Molimo vas da unesete svoju poruku."

msgid "emails.versionCreated.subject"
msgstr "Kreirana je nova verzija za „{$submissionTitle}“"

msgid "emails.versionCreated.body"
msgstr ""
"<p>Poštovani/a {$recipientName}, </p><p>Ovo je automatska poruka kojom vas "
"obaveštavamo da je kreirana nova verzija vaše prijave „{$submissionTitle}“. "
"Ovu verziju možete pregledati putem kontrolne table prijave na sledećem "
"linku:</p><p><a href=\"{$submissionUrl}\">„{$submissionTitle}“</a></"
"p><hr><p>Ovo je automatska poruka poslata iz <a href=\"{$contextUrl}\""
">{$contextName}</a>.</p>"

msgid "emails.reviewComplete.subject"
msgstr ""
"Recenzija završena: {$reviewerName} preporučuje {$reviewRecommendation} za "
"#{$submissionId} {$authorsShort} — „{$submissionTitle}“"

msgid "emails.reviewComplete.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>{$reviewerName} je završio/la sledeću "
"recenziju:</p><p><a href=\"{$submissionUrl}\">#{$submissionId} "
"{$authorsShort} — „{$submissionTitle}“</a><br /><b>Preporuka:</b> "
"{$reviewRecommendation}<br /><b>Tip:</b> {$reviewMethod}</p><p>Prijavite se "
"da biste <a href=\"{$submissionUrl}\">pregledali sve fajlove i komentare</a> "
"koje je dostavio/la ovaj recenzent.</p>"

msgid "emails.reviewEdit.subject"
msgstr "Vaš zadatak recenzije je izmenjen za {$contextName}"

msgid "emails.reviewEdit.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Urednik je izvršio izmene u vašem "
"zadatku recenzije za {$contextName}. Molimo vas da pregledate detalje u "
"nastavku i obavestite nas ukoliko imate bilo kakvih pitanja.</p><p><a href=\""
"{$reviewAssignmentUrl}\">„{$submissionTitle}“</a><br /><b>Tip:</b> "
"{$reviewMethod}<br /><b>Prihvatite ili odbijte do:</b> {$responseDueDate}<br "
"/><b>Rok za slanje recenzije:</b> {$reviewDueDate}</p><p>Možete se prijaviti "
"i <a href=\"{$reviewAssignmentUrl}\">završiti ovu recenziju</a> u bilo kom "
"trenutku.</p>"

msgid "emails.reviewConfirm.subject"
msgstr ""
"Prihvaćena recenzija: {$reviewerName} je prihvatio/la zadatak recenzije za "
"#{$submissionId} {$authorsShort} — „{$submissionTitle}“"

msgid "emails.reviewConfirm.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>{$reviewerName} je prihvatio/la "
"sledeći zadatak recenzije:</p><p><a href=\"{$submissionUrl}\""
">#{$submissionId} {$authorsShort} — „{$submissionTitle}“</a><br /><b>Tip:</"
"b> {$reviewMethod}</p><p><b>Rok za recenziju:</b> {$reviewDueDate}</"
"p><p>Prijavite se da biste <a href=\"{$submissionUrl}\">pregledali sve "
"dodeljene recenzije</a> za ovaj rad.</p><br><br>—<br>Ovo je automatska "
"poruka iz <a href=\"{$contextUrl}\">{$contextName}</a>."

msgid "emails.submissionSavedForLater.subject"
msgstr "Nastavite sa predajom rada u {$contextName}"

msgid "emails.submissionSavedForLater.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Detalji vaše prijave su sačuvani u "
"našem sistemu, ali prijava još uvek nije poslata na razmatranje. Možete se "
"vratiti i dovršiti prijavu u bilo kom trenutku putem sledećeg linka.</"
"p><p><a href=\"{$submissionWizardUrl}\">{$authorsShort} — "
"„{$submissionTitle}“</a></p><hr><p>Ovo je automatska poruka iz <a href=\""
"{$contextUrl}\">{$contextName}</a>.</p>"

msgid "emails.submissionNeedsEditor.subject"
msgstr "Novom predatom radu je potrebno dodeliti urednika: „{$submissionTitle}“"

msgid "emails.submissionNeedsEditor.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Sledeći rad je poslat, ali nije "
"dodeljen urednik.</p><p><a href=\"{$submissionUrl}\">„{$submissionTitle}“</"
"a><br />{$authors}</p><p><b>Apstrakt</b></p>{$submissionAbstract}<p>Molimo "
"vas da dodelite urednika koji će biti odgovoran za ovaj rad tako što ćete "
"kliknuti na naslov iznad i dodeliti urednika u odeljku „Učesnici“.</p><p>Ovo "
"je automatska poruka iz <a href=\"{$contextUrl}\">{$contextName}</a>.</p>"

msgid "emails.submissionAckNotUser.description"
msgstr ""
"Ovaj imejl se automatski šalje autorima navedenim na novom radu koji nisu "
"autor koji je izvršio podnošenje."

msgid "emails.submissionAckNotAuthor.subject"
msgstr "Potvrda rada"

msgid "emails.submissionAckNotAuthor.body"
msgstr ""
"<p>Poštovani/a {$recipientName},</p><p>Navedeni ste kao koautor rada za "
"{$contextName}. Podnosilac rada, {$submitterName}, naveo je sledeće "
"podatke:</p><p>„{$submissionTitle}“<br>{$authorsWithAffiliation}</p><p>Ako "
"su ovi podaci netačni ili ne želite da budete navedeni kao autor ovog rada, "
"molimo vas da me kontaktirate.</p><p>Hvala vam što razmatrate {$contextName} "
"kao mesto za objavljivanje vašeg rada.</p><p>Srdačan "
"pozdrav,</p>{$contextSignature}"

